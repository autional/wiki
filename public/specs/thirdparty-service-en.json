        }
      }
    },
    "dto.DataResponse-gitee_com_linmes_authms_micro-services_thirdparty-service_internal_dto_ExportUserDataResponse": {
      "type": "object",
      "properties": {
        "code": {
          "type": "integer"
        },
        "data": {
          "$ref": "#/definitions/gitee_com_linmes_authms_micro-services_thirdparty-service_internal_dto.ExportUserDataResponse"
        },
        "message": {
          "type": "string"
