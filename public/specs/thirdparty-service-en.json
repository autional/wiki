        "code": {
          "type": "integer"
        },
        "data": {
          "$ref": "#/definitions/gitee_com_linmes_authms_micro-services_thirdparty-service_internal_dto.CaptchaVerifyResponse"
        },
        "message": {
          "type": "string"
