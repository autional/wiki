---
import '../styles/global.css';
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '@fontsource/inter/700.css';
import '@fontsource/inter/800.css';

const services = [
  { name:'identity-service', title:'Identity Service', port:11001 },
  { name:'profile-service', title:'Profile Service', port:11002 },
  { name:'tenant-service', title:'Tenant Service', port:11003 },
  { name:'session-service', title:'Session Service', port:11004 },
  { name:'mfa-service', title:'MFA Service', port:11005 },
  { name:'oauth-service', title:'OAuth Service', port:11006 },
  { name:'wallet-service', title:'Wallet Service', port:11011 },
  { name:'point-service', title:'Point Service', port:11012 },
  { name:'audit-service', title:'Audit Service', port:11013 },
  { name:'notification-service', title:'Notification Service', port:11014 },
  { name:'communication-service', title:'Communication Service', port:11015 },
  { name:'storage-service', title:'Storage Service', port:11016 },
  { name:'billing-service', title:'Billing Service', port:11017 },
  { name:'compliance-service', title:'Compliance Service', port:11018 },
  { name:'status-service', title:'Status Service', port:11019 },
  { name:'secret-service', title:'Secret Service', port:11020 },
  { name:'saml-service', title:'SAML Service', port:11021 },
  { name:'pay-service', title:'Pay Service', port:11022 },
  { name:'thirdparty-service', title:'Thirdparty Service', port:11023 },
  { name:'verification-service', title:'Verification Service', port:11024 },
  { name:'rbac-service', title:'RBAC Service', port:11025 },
  { name:'gateway-service', title:'Gateway Service', port:11080 },
];

const { title = 'Aucial API Wiki' } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
const currentSvc = Astro.url.pathname.split('/')[1] || '';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1.0">
  <title>{title}</title>
  <link rel="canonical" href={canonical.href}>
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png?v=7">
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png?v=7">
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png?v=7">
  <link rel="manifest" href="/site.webmanifest?v=7">
  <meta name="theme-color" content="#003153">
</head>
<body class="min-h-screen antialiased">
  <!-- Top bar -->
  <header class="sticky top-0 z-50 h-14 flex items-center justify-between px-6 border-b border-primary-100/70 bg-white/90 backdrop-blur-xl">
    <a href="/" class="flex items-center gap-2.5 no-underline">
      <img src="/logo-mark.svg" alt="Aucial" class="h-7 w-7 object-contain">
      <span class="text-[1.05rem] font-extrabold tracking-[-0.03em] text-primary-900">Aucial</span>
      <span class="hidden sm:inline text-[0.65rem] font-semibold uppercase tracking-[0.22em] text-primary-400 ml-1.5">API Wiki</span>
    </a>
    <div class="flex items-center gap-5">
      <a href="https://reference.aucial.com" class="text-xs font-medium text-primary-500 hover:text-primary-700 transition">API Reference</a>
      <a href="https://www.aucial.com" class="text-xs font-medium text-primary-500 hover:text-primary-700 transition">aucial.com &rarr;</a>
    </div>
  </header>

  <div class="flex h-[calc(100vh-56px)] overflow-hidden">
    <!-- Sidebar -->
    <aside class="w-60 shrink-0 border-r border-primary-100/50 bg-white overflow-y-auto">
      <div class="sticky top-0 bg-white/95 backdrop-blur border-b border-primary-100/50 px-4 py-3 z-10">
        <span class="text-[0.65rem] font-bold uppercase tracking-[0.18em] text-primary-500">Services</span>
      </div>
      <nav class="py-2">
        {services.map(s => {
          const active = currentSvc === s.name;
          return (
            <a href={`/${s.name}/`} class={`group flex items-center justify-between mx-2 my-0.5 rounded-xl px-3 py-2 transition text-sm ${
              active
                ? 'bg-primary-700 text-white shadow-soft'
                : 'text-neutral-600 hover:bg-primary-50 hover:text-primary-800'
            }`}>
              <span class="font-medium truncate">{s.title}</span>
              {active && <span class="text-[0.6rem] opacity-60 font-mono ml-1 shrink-0">{s.port}</span>}
            </a>
          );
        })}
      </nav>
    </aside>

    <!-- Main content area -->
    <div class="flex-1 flex overflow-hidden bg-neutral-50/50">
      <slot />
    </div>
  </div>
</body>
</html>
