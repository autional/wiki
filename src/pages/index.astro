---
import WikiLayout from '../layouts/WikiLayout.astro';

const services = [
  { name:'identity-service', title:'Identity Service', port:11001 },
  { name:'profile-service', title:'Profile Service', port:11002 },
  { name:'tenant-service', title:'Tenant Service', port:11003 },
  { name:'session-service', title:'Session Service', port:11004 },
  { name:'mfa-service', title:'MFA Service', port:11005 },
  { name:'oauth-service', title:'OAuth Service', port:11006 },
  { name:'wallet-service', title:'Wallet Service', port:11011 },
  { name:'point-service', title:'Point Service', port:11012 },
  { name:'audit-service', title:'Audit Service', port:11013 },
  { name:'notification-service', title:'Notification Service', port:11014 },
  { name:'communication-service', title:'Communication Service', port:11015 },
  { name:'storage-service', title:'Storage Service', port:11016 },
  { name:'billing-service', title:'Billing Service', port:11017 },
  { name:'compliance-service', title:'Compliance Service', port:11018 },
  { name:'status-service', title:'Status Service', port:11019 },
  { name:'secret-service', title:'Secret Service', port:11020 },
  { name:'saml-service', title:'SAML Service', port:11021 },
  { name:'pay-service', title:'Pay Service', port:11022 },
  { name:'thirdparty-service', title:'Thirdparty Service', port:11023 },
  { name:'verification-service', title:'Verification Service', port:11024 },
  { name:'rbac-service', title:'RBAC Service', port:11025 },
  { name:'gateway-service', title:'Gateway Service', port:11080 },
];
---

<WikiLayout title="API Wiki — Autional">
  <div class="flex-1 overflow-y-auto">
    <div class="max-w-4xl mx-auto px-8 py-10">
      <div class="mb-10">
        <h1 class="text-3xl font-extrabold tracking-[-0.04em] text-primary-900">API Wiki</h1>
        <p class="mt-2 text-base text-neutral-500 leading-relaxed max-w-lg">
          Detailed endpoint documentation for all {services.length} microservices.
          Select a service to browse its API reference.
        </p>
        <div class="mt-4 flex items-center gap-2 flex-wrap">
          <span class="brand-kicker">OpenAPI 3.0</span>
          <span class="text-xs text-neutral-400 font-mono">{services.length} services</span>
        </div>
      </div>

      <!-- Service cards grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
        {services.map(s => (
          <a href={`/${s.name}/`} class="group block rounded-2xl border border-primary-100/80 bg-white p-5 transition hover:border-primary-300 hover:shadow-card hover:-translate-y-0.5 no-underline">
            <div class="flex items-start justify-between">
              <h3 class="text-sm font-semibold text-primary-900 group-hover:text-primary-700 transition">{s.title}</h3>
              <span class="text-[0.65rem] font-mono text-primary-400 shrink-0 mt-0.5">:{s.port}</span>
            </div>
            <div class="mt-3 flex items-center gap-2">
              <span class="text-[0.7rem] font-medium text-primary-500">Browse endpoints &rarr;</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>
</WikiLayout>
