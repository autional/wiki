---
import WikiLayout from '../layouts/WikiLayout.astro';
---

<WikiLayout title="API Wiki — Aucial">
  <div class="flex-1 flex flex-col items-center justify-center p-12 text-center">
    <h1 class="text-3xl font-extrabold tracking-tight text-neutral-900">Aucial API Wiki</h1>
    <p class="mt-3 text-neutral-500 max-w-md">Detailed endpoint documentation for all 22 microservices. Select a service from the left sidebar to browse its API.</p>
    <div class="mt-8 flex flex-wrap justify-center gap-2 text-xs text-neutral-400 font-mono">
      <span>270 eps</span><span>·</span><span>OpenAPI 3.0</span><span>·</span><span>English</span>
    </div>
  </div>
</WikiLayout>
