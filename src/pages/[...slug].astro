---
import { readFileSync, readdirSync } from 'node:fs';
import { join } from 'node:path';
import WikiLayout from '../layouts/WikiLayout.astro';

export async function getStaticPaths() {
  const apiDir = join(process.cwd(), 'public/wiki/api');
  const slugs: string[] = [];

  function scan(dir: string, base: string) {
    const entries = readdirSync(dir, { withFileTypes: true });
    for (const entry of entries) {
      if (entry.isDirectory()) {
        scan(join(dir, entry.name), base ? `${base}/${entry.name}` : entry.name);
      } else if (entry.name === 'index.html' && base) {
        slugs.push(base);
      }
    }
  }
  scan(apiDir, '');

  return slugs.map(slug => ({ params: { slug } }));
}

const { slug } = Astro.params;
const htmlPath = join(process.cwd(), 'public/wiki/api', slug ?? '', 'index.html');
let pageTitle = slug?.split('/').pop() || 'API Wiki';
let description = '';
let mainContent = '';
let inlineStyles = '';
let jsonLdScripts: Record<string, any>[] = [];

try {
  const html = readFileSync(htmlPath, 'utf-8');

  const titleMatch = html.match(/<title>(.*?)<\/title>/);
  if (titleMatch) pageTitle = titleMatch[1];

  const descMatch = html.match(/<meta name="description" content="([^"]*)"/);
  if (descMatch) description = descMatch[1];

  const styleMatch = html.match(/<style>([\s\S]*?)<\/style>/);
  if (styleMatch) inlineStyles = styleMatch[1];

  const mainMatch = html.match(/<main[^>]*class="[^"]*main-content[^"]*"[^>]*>([\s\S]*?)<\/main>/);
  if (mainMatch) {
    mainContent = mainMatch[1];
  } else {
    // Fallback: extract body content minus header/sidebar/footer
    const bodyMatch = html.match(/<body[^>]*>([\s\S]*?)<\/body>/);
    if (bodyMatch) mainContent = bodyMatch[1];
  }

  const jsonLdRe = /<script type="application\/ld\+json">([\s\S]*?)<\/script>/g;
  let m;
  while ((m = jsonLdRe.exec(html)) !== null) {
    try { jsonLdScripts.push(JSON.parse(m[1])); } catch {}
  }
} catch {
  mainContent = `<p class="text-neutral-500">Content not found for: ${slug}</p>`;
}

const isEndpointDetail = (slug?.split('/').length || 0) > 1;
---

<WikiLayout
  title={pageTitle}
  description={description}
  jsonLd={jsonLdScripts}
  ogType={isEndpointDetail ? 'article' : 'website'}
>
  <div class="flex-1 overflow-y-auto bg-neutral-50/50">
    <div class="wiki-rendered px-8 py-10 max-w-4xl">
      {inlineStyles && <style set:html={inlineStyles} />}
      <div class="wiki-content" set:html={mainContent} />
    </div>
  </div>
</WikiLayout>
